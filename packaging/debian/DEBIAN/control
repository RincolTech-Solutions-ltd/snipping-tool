Package: snipping-tool
Version: 1.0.0
Section: graphics
Priority: optional
Architecture: all
Depends: python3 (>= 3.8), python3-gi, python3-gi-cairo, gir1.2-gtk-3.0, gir1.2-gdk-3.0, gir1.2-gdkpixbuf-2.0, gir1.2-keybinder-3.0, libkeybinder-3.0-0, python3-pil, python3-cairo, xclip
Recommends: libappindicator3-1, gir1.2-appindicator3-0.1
